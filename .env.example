# Amz-Keepa-MCP 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# 必需配置
# ============================================

# Keepa API Key (必需)
# 获取地址: https://keepa.com/#!api
KEEPA_KEY=your_keepa_api_key_here

# ============================================
# 可选配置
# ============================================

# 默认站点 (US, CN, JP, DE, UK, FR, IT, ES, CA, MX, IN, BR, AU, TR, AE, SA, NL, SE, PL, SG)
KEEPA_DOMAIN=US

# 缓存设置
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# 1688 API 配置 (可选，用于自动获取采购价格)
# ============================================

# TMAPI Token (推荐，最简单)
# 获取地址: https://tmapi.top
# 注册后获取API Token，支持以图搜图获取1688采购价格
TMAPI_TOKEN=your_tmapi_token_here

# 1688官方开放平台 (备选，需要企业资质)
# 获取地址: https://open.1688.com
# 需要申请开发者账号，创建应用获取App Key和App Secret
ALIBABA_APP_KEY=your_alibaba_app_key
ALIBABA_APP_SECRET=your_alibaba_app_secret

# 成本计算参数
SHIPPING_RATE=12          # 船运价格 RMB/kg
EXCHANGE_RATE=7.2         # 汇率 RMB/USD
TARIFF_RATE=0.15          # 关税率 15%
